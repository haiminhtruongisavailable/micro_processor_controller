void update_inactivity_timer() {
   inactivity_timer += 10;
}

void check_typing_timeout() {
   if (inactivity_timer >= 5000) {
      do_action('E');
      go_to_idle();
   }
}

void check_unlocked_timeout() {
   if (inactivity_timer >= 15000) {
      go_to_idle();
      do_action('R');
   }
   else if (inactivity_timer >= 12000 && !reminder_sent) {
      do_action('M');
      reminder_sent = 1;
   }
}

void process_key_in_typing(char key) {
   if (key >= '0' && key <= '9') {
      if (idx < PASS_LEN) { entered[idx++] = key; do_action('K'); }
      else { RED_ON; do_action('E'); RED_OFF; }
   }
   else if (key == '-') { ... }      // keep your original logic
   else if (key == '%') { do_action('E'); go_to_idle(); }
   else if (key == '=') { ... }      // password check
}

void process_key_in_unlocked(char key) {
   if (key == '*') { inactivity_timer = 0; do_action('S'); }
   else if (key == '%') { go_to_idle(); do_action('R'); }
   else do_action('E');
}

