#include <16F887.h>
#fuses HS,NOWDT,NOPROTECT,NOLVP
#use delay(clock=20000000)
#use fast_io(B)
#use fast_io(C)
#use fast_io(D)

#byte ANSEL  = 0x188
#byte ANSELH = 0x189

#define PASS_LEN 4
#define MAX_WRONG 3
const char PASSWORD[] = "1234";

// ==================== HARDWARE ====================
#define GREEN_ON     output_high(PIN_B1)
#define GREEN_OFF    output_low(PIN_B1)
#define RED_ON       output_high(PIN_B2)
#define RED_OFF      output_low(PIN_B2)
#define BUZZER_ON    output_high(PIN_C1)
#define BUZZER_OFF   output_low(PIN_C1)
#define SERVO_HIGH   output_high(PIN_C2)
#define SERVO_LOW    output_low(PIN_C2)

// ==================== FSM ====================
typedef enum {
    STATE_IDLE,
    STATE_TYPING,
    STATE_UNLOCKED,
    STATE_ALARM
} SystemState;

typedef enum {
    EVENT_NONE,
    EVENT_DIGIT,
    EVENT_BACKSPACE,
    EVENT_SUBMIT,
    EVENT_CANCEL,
    EVENT_EXTEND
} FSMEvent;

SystemState current_state = STATE_IDLE;
int8  idx = 0;
char  entered[6];
int8  wrong_attempts = 0;
int16 inactivity_ms = 0;          // now in milliseconds
char  last_key = 0;

// ==================== NON-BLOCKING TIMERS & SEQUENCERS ====================
volatile int16 system_tick_ms = 0;   // incremented by Timer2 ISR

// Buzzer sequencer (non-blocking)
int16 buzzer_timer_ms = 0;
int8  buzzer_pattern = 0;   // 0=off, 1=success, 2=error, 3=ready, 4=key, 5=delete, 6=chirp

// Alarm sequencer
int1  alarm_active = 0;
int16 alarm_timer_ms = 0;

// Servo pulse scheduler (non-blocking)
int1  servo_open_pending = 0;
int1  servo_close_pending = 0;

// ==================== HARDWARE FUNCTIONS (now non-blocking) ====================
void start_beep(int8 pattern) {
    buzzer_pattern = pattern;
    buzzer_timer_ms = 0;          // will be set by the pattern below
}

void servo_pulse_open()  { SERVO_HIGH; delay_us(2050); SERVO_LOW; }   // single short pulse
void servo_pulse_closed(){ SERVO_HIGH; delay_us(1496); delay_cycles(11); SERVO_LOW; }

// ==================== INPUT DECODER ====================
FSMEvent decode_event(char key, int1 edge) {
    if (!edge) return EVENT_NONE;
    if (key >= '0' && key <= '9') return EVENT_DIGIT;
    if (key == '-')               return EVENT_BACKSPACE;
    if (key == '=')               return EVENT_SUBMIT;
    if (key == '%')               return EVENT_CANCEL;
    if (key == '*')               return EVENT_EXTEND;
    return EVENT_NONE;
}

// ==================== PASSWORD CHECK ====================
int1 password_match() {
    if (idx != PASS_LEN) return 0;
    for (int8 i = 0; i < PASS_LEN; i++) {
        if (entered[i] != PASSWORD[i]) return 0;
    }
    return 1;
}

// ==================== STATE ENTRY ACTIONS ====================
void go_to_idle() {
    current_state = STATE_IDLE;
    idx = 0;
    for (int8 i = 0; i < 6; i++) entered[i] = 0;
    GREEN_OFF;
    servo_close_pending = 1;      // request close servo
    alarm_active = 0;
}

void go_to_unlocked() {
    current_state = STATE_UNLOCKED;
    wrong_attempts = 0;
    inactivity_ms = 0;
    GREEN_ON;
    start_beep(1);                // success beep
    servo_open_pending = 1;       // request open servo
}

void go_to_alarm() {
    current_state = STATE_ALARM;
    alarm_active = 1;
    alarm_timer_ms = 15000;       // 15 seconds of siren
}

// ==================== EMERGENCY RESET ISR ====================
#int_ext
void ext_isr(void) {
    wrong_attempts = 0;
    go_to_idle();
    GREEN_ON; delay_ms(300); GREEN_OFF;   // very short flash - acceptable here
    start_beep(3);                        // ready beep
}

// ==================== TIMER2 - 10ms SYSTEM TICK ====================
#int_timer2
void timer2_isr(void) {
    system_tick_ms += 10;                 // every interrupt = +10 ms
}

char scan_matrix() {
   char k = 0;
   output_high(PIN_D0); delay_us(20);
   if(input(PIN_D4)) k = '7'; else if(input(PIN_D5)) k = '8'; else if(input(PIN_D6)) k = '9'; else if(input(PIN_D7)) k = '/';
   output_low(PIN_D0);
   if (k) return k;

   output_high(PIN_D1); delay_us(20);
   if(input(PIN_D4)) k = '4'; else if(input(PIN_D5)) k = '5'; else if(input(PIN_D6)) k = '6'; else if(input(PIN_D7)) k = '*';
   output_low(PIN_D1);
   if (k) return k;

   output_high(PIN_D2); delay_us(20);
   if(input(PIN_D4)) k = '1'; else if(input(PIN_D5)) k = '2'; else if(input(PIN_D6)) k = '3'; else if(input(PIN_D7)) k = '-';
   output_low(PIN_D2);
   if (k) return k;

   output_high(PIN_D3); delay_us(20);
   if(input(PIN_D4)) k = '%'; else if(input(PIN_D5)) k = '0'; else if(input(PIN_D6)) k = '='; else if(input(PIN_D7)) k = '+';
   output_low(PIN_D3);
   return k;
}
// ==================== BUZZER & ALARM UPDATE (called every 10ms) ====================
void update_audio_and_servo() {
    // --- Buzzer pattern handler ---
    if (buzzer_timer_ms > 0) {
        buzzer_timer_ms -= 10;
    } else {
        BUZZER_OFF;
        if (buzzer_pattern == 0) return;

        // Simple non-blocking beep sequences
        switch (buzzer_pattern) {
            case 1: // success (two short)
                if (buzzer_timer_ms == 0) { BUZZER_ON; buzzer_timer_ms = 40; buzzer_pattern = 10; } break;
            case 10: BUZZER_OFF; buzzer_timer_ms = 40; buzzer_pattern = 11; break;
            case 11: BUZZER_ON;  buzzer_timer_ms = 40; buzzer_pattern = 12; break;
            case 12: BUZZER_OFF; buzzer_pattern = 0; break;

            case 2: // error (two long)
                BUZZER_ON; buzzer_timer_ms = 400; buzzer_pattern = 20; break;
            case 20: BUZZER_OFF; buzzer_timer_ms = 200; buzzer_pattern = 21; break;
            case 21: BUZZER_ON;  buzzer_timer_ms = 400; buzzer_pattern = 22; break;
            case 22: BUZZER_OFF; buzzer_pattern = 0; break;

            case 3: // ready
                BUZZER_ON; buzzer_timer_ms = 30; buzzer_pattern = 30; break;
            case 30: BUZZER_OFF; buzzer_timer_ms = 50; buzzer_pattern = 31; break;
            case 31: BUZZER_ON;  buzzer_timer_ms = 30; buzzer_pattern = 32; break;
            case 32: BUZZER_OFF; buzzer_pattern = 0; break;

            case 4: // key tick
                BUZZER_ON; buzzer_timer_ms = 5; buzzer_pattern = 40; break;
            case 40: BUZZER_OFF; buzzer_pattern = 0; break;

            case 5: // delete tick
                BUZZER_ON; buzzer_timer_ms = 15; buzzer_pattern = 50; break;
            case 50: BUZZER_OFF; buzzer_pattern = 0; break;

            case 6: // reminder chirp
                BUZZER_ON; buzzer_timer_ms = 10; buzzer_pattern = 60; break;
            case 60: BUZZER_OFF; buzzer_timer_ms = 20; buzzer_pattern = 61; break;
            case 61: BUZZER_ON;  buzzer_timer_ms = 10; buzzer_pattern = 62; break;
            case 62: BUZZER_OFF; buzzer_pattern = 0; break;
        }
    }

    // --- Alarm siren (non-blocking) ---
    if (alarm_active && alarm_timer_ms > 0) {
        alarm_timer_ms -= 10;
        static int8 phase = 0;
        phase = (phase + 1) % 35;                    // ~350ms cycle
        if (phase < 20) { RED_ON; BUZZER_ON; }      // fast beep
        else            { RED_OFF; BUZZER_OFF; }
    } else if (alarm_active) {
        alarm_active = 0;
        RED_OFF; BUZZER_OFF;
        go_to_idle();
        start_beep(3);
    }

    // --- Servo pulses (non-blocking) ---
    if (servo_open_pending)  { servo_pulse_open();  servo_open_pending = 0; }
    if (servo_close_pending) { servo_pulse_closed(); servo_close_pending = 0; }
}

// ==================== MAIN ====================
void main() {
    ANSEL = 0x00; ANSELH = 0x00;
    set_tris_b(0x01);
    set_tris_c(0x00);
    set_tris_d(0xF0);
    output_b(0x00); output_c(0x00); output_d(0x00);

    // Timer2 = 10 ms tick
    setup_timer_2(T2_DIV_BY_16, 194, 16);   // exactly ~10 ms at 20 MHz
    enable_interrupts(INT_TIMER2);
    enable_interrupts(INT_EXT);
    ext_int_edge(L_TO_H);
    enable_interrupts(GLOBAL);

    go_to_idle();
    start_beep(3);        // boot ready beep

    while (TRUE) {
        // 1. Keypad scan (edge detection)
        char key = scan_matrix();
        int1 key_edge = (key != 0 && last_key == 0);
        last_key = key;
        FSMEvent event = decode_event(key, key_edge);

        // 2. Update all non-blocking stuff every loop
        update_audio_and_servo();

        // 3. Timer tick processing (only when 10 ms passed)
        static int16 last_tick = 0;
        if (system_tick_ms - last_tick >= 10) {
            last_tick = system_tick_ms;

            // Inactivity timers
            if (current_state == STATE_TYPING || current_state == STATE_UNLOCKED) {
                inactivity_ms += 10;
            }

            // FSM next-state logic (exactly like before, but now fully non-blocking)
            SystemState next = current_state;

            switch (current_state) {
                case STATE_IDLE:
                    if (event == EVENT_DIGIT) next = STATE_TYPING;
                    break;

                case STATE_TYPING:
                    if (inactivity_ms >= 5000) {
                        start_beep(2);
                        next = STATE_IDLE;
                    } else if (event == EVENT_DIGIT) {
                        if (idx < PASS_LEN) {
                            entered[idx++] = key;
                            start_beep(4);           // key tick
                        }
                    } else if (event == EVENT_BACKSPACE) {
                        if (idx > 0) {
                            idx--;
                            entered[idx] = 0;
                            start_beep(5);
                            if (idx == 0) next = STATE_IDLE;
                        } else next = STATE_IDLE;
                    } else if (event == EVENT_CANCEL) {
                        start_beep(2);
                        next = STATE_IDLE;
                    } else if (event == EVENT_SUBMIT) {
                        if (password_match()) {
                            next = STATE_UNLOCKED;
                        } else {
                            wrong_attempts++;
                            start_beep(2);
                            RED_ON; delay_ms(1000); RED_OFF;   // short flash only
                            if (wrong_attempts >= MAX_WRONG) {
                                next = STATE_ALARM;
                            } else {
                                next = STATE_IDLE;
                            }
                        }
                    }
                    break;

                case STATE_UNLOCKED:
                    if (inactivity_ms >= 15000) {
                        next = STATE_IDLE;
                    } else if (inactivity_ms == 12000) {
                        start_beep(6);                     // reminder chirp
                    } else if (event == EVENT_EXTEND) {
                        inactivity_ms = 0;
                        start_beep(1);
                    } else if (event == EVENT_CANCEL) {
                        next = STATE_IDLE;
                    }
                    break;

                case STATE_ALARM:
                    // handled completely by update_audio_and_servo()
                    break;
            }

            // Apply state change + entry actions
            if (next != current_state) {
                current_state = next;
                if (current_state == STATE_IDLE)     go_to_idle();
                if (current_state == STATE_UNLOCKED) go_to_unlocked();
                if (current_state == STATE_ALARM)    go_to_alarm();
            }
        }

        delay_us(100);   // very short sleep - keeps loop responsive
    }
}
